{
  "@context": {
    "@vocab": "https://archivelab.co.kr/ns/busan-refuge#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "name": "rdfs:label",
    "description": "rdfs:comment",
    "lat": { "@id": "geo:lat", "@type": "xsd:decimal" },
    "lng": { "@id": "geo:long", "@type": "xsd:decimal" },
    "date": { "@id": "date", "@type": "xsd:date" },
    "placeType": "placeType",
    "atPlace": { "@type": "@id" },
    "evacuatedFrom": { "@type": "@id" },
    "evacuatedTo": { "@type": "@id" },
    "relocatedTo": { "@type": "@id" },
    "stayedAt": { "@type": "@id" },
    "residedAt": { "@type": "@id" },
    "gatheredAt": { "@type": "@id" },
    "settledAt": { "@type": "@id" },
    "workedAt": { "@type": "@id" },
    "frequented": { "@type": "@id" },
    "created": { "@type": "@id" },
    "wrote": { "@type": "@id" },
    "usedAsOffice": { "@type": "@id" },
    "formedAt": { "@type": "@id" },
    "createdAt": { "@type": "@id" },
    "setIn": { "@type": "@id" },
    "locatedIn": { "@type": "@id" },
    "involvedIn": { "@type": "@id" },
    "partOf": { "@type": "@id" },
    "occurredAt": { "@type": "@id" }
  },

  "@graph": [
    { "@id": "#Agent",  "@type": "rdfs:Class", "name": "행위자", "description": "사건을 일으키거나 작품을 만드는 주체" },
    { "@id": "#Person", "@type": "rdfs:Class", "rdfs:subClassOf": { "@id": "#Agent" }, "name": "인물" },
    { "@id": "#Group",  "@type": "rdfs:Class", "rdfs:subClassOf": { "@id": "#Agent" }, "name": "집단·기관" },
    { "@id": "#Place",  "@type": "rdfs:Class", "name": "장소" },
    { "@id": "#Event",  "@type": "rdfs:Class", "name": "사건" },
    { "@id": "#Work",   "@type": "rdfs:Class", "name": "작품" },

    { "@id": "person:이중섭", "@type": "Person", "name": "이중섭",
      "evacuatedFrom": "place:원산", "stayedAt": "place:영도", "created": "work:은지화" },
    { "@id": "person:김환기", "@type": "Person", "name": "김환기",
      "evacuatedTo": "place:부산", "workedAt": "place:광복동" },
    { "@id": "person:윤이상", "@type": "Person", "name": "윤이상", "workedAt": "place:부산" },
    { "@id": "person:김동리", "@type": "Person", "name": "김동리",
      "frequented": "place:밀다원다방", "wrote": "work:밀다원시대" },
    { "@id": "person:이승만", "@type": "Person", "name": "이승만",
      "residedAt": "place:임시수도대통령관저", "involvedIn": "event:부산정치파동" },

    { "@id": "group:대한민국정부", "@type": "Group", "name": "대한민국정부",
      "relocatedTo": "place:부산", "usedAsOffice": "place:임시수도정부청사" },
    { "@id": "group:피란민", "@type": "Group", "name": "피란민",
      "gatheredAt": ["place:국제시장", "place:40계단", "place:부산항"],
      "settledAt": ["place:우암동소막마을", "place:아미동비석마을", "place:감천문화마을"] },
    { "@id": "group:헌책방", "@type": "Group", "name": "헌책방", "formedAt": "place:보수동책방골목" },

    { "@id": "place:부산", "@type": "Place", "name": "부산", "placeType": "도시", "lat": 35.1000, "lng": 129.0350, "description": "한국전쟁기 임시수도가 된 항구도시" },
    { "@id": "place:영도", "@type": "Place", "name": "영도", "placeType": "섬", "lat": 35.0912, "lng": 129.0679, "description": "피란 예술가와 피란민이 머문 섬" },
    { "@id": "place:국제시장", "@type": "Place", "name": "국제시장", "placeType": "시장", "lat": 35.0985, "lng": 129.0286, "description": "피란민 상권의 중심이자 1953년 대화재가 난 곳" },
    { "@id": "place:40계단", "@type": "Place", "name": "40계단", "placeType": "장소", "lat": 35.1078, "lng": 129.0357, "description": "피란민이 모이고 이산가족이 만나던 계단" },
    { "@id": "place:부산항", "@type": "Place", "name": "부산항", "placeType": "항구", "lat": 35.0966, "lng": 129.0420, "description": "구호물자와 피란민이 오가던 관문" },
    { "@id": "place:자갈치시장", "@type": "Place", "name": "자갈치시장", "placeType": "시장", "lat": 35.0965, "lng": 129.0305, "description": "피란기에 형성된 수산물 시장" },
    { "@id": "place:광복동", "@type": "Place", "name": "광복동", "placeType": "거리", "lat": 35.0989, "lng": 129.0323, "description": "피란 문화예술인이 모이던 번화가" },
    { "@id": "place:밀다원다방", "@type": "Place", "name": "밀다원다방", "placeType": "다방", "lat": 35.0992, "lng": 129.0320, "description": "피란 문인들의 사랑방", "locatedIn": "place:광복동" },
    { "@id": "place:임시수도정부청사", "@type": "Place", "name": "임시수도정부청사", "placeType": "관청", "lat": 35.0995, "lng": 129.0240, "description": "임시수도기 정부청사(현 동아대 석당박물관)" },
    { "@id": "place:임시수도대통령관저", "@type": "Place", "name": "임시수도대통령관저", "placeType": "관저", "lat": 35.0972, "lng": 129.0228, "description": "임시수도기 대통령 관저(현 임시수도기념관)" },
    { "@id": "place:보수동책방골목", "@type": "Place", "name": "보수동책방골목", "placeType": "거리", "lat": 35.1016, "lng": 129.0270, "description": "피란기 헌책방이 모여 형성된 골목" },
    { "@id": "place:우암동소막마을", "@type": "Place", "name": "우암동소막마을", "placeType": "마을", "lat": 35.1207, "lng": 129.0665, "description": "소 막사를 개조해 피란민이 정착한 마을" },
    { "@id": "place:아미동비석마을", "@type": "Place", "name": "아미동비석마을", "placeType": "마을", "lat": 35.0960, "lng": 129.0175, "description": "일제기 공동묘지 위에 형성된 피란 정착촌" },
    { "@id": "place:감천문화마을", "@type": "Place", "name": "감천문화마을", "placeType": "마을", "lat": 35.0975, "lng": 129.0107, "description": "산비탈에 형성된 피란 정착 마을" },
    { "@id": "place:원산", "@type": "Place", "name": "원산", "placeType": "도시", "lat": 39.1538, "lng": 127.4444, "description": "이중섭 등 예술가들의 피란 출발지(현 북한)" },

    { "@id": "event:정부임시수도부산이전", "@type": "Event", "name": "정부 임시수도 부산 이전", "date": "1950-08-18", "occurredAt": "place:부산", "description": "대한민국 정부가 부산을 임시수도로 정하고 이전" },
    { "@id": "event:1·4후퇴", "@type": "Event", "name": "1·4 후퇴", "date": "1951-01-04", "occurredAt": "place:부산", "description": "서울 재함락으로 정부와 피란민이 다시 부산으로 집결" },
    { "@id": "event:부산정치파동", "@type": "Event", "name": "부산정치파동", "date": "1952-05-26", "occurredAt": "place:부산", "description": "대통령 직선제 개헌을 둘러싼 정치적 충돌" },
    { "@id": "event:발췌개헌", "@type": "Event", "name": "발췌개헌", "date": "1952-07-04", "occurredAt": "place:부산", "partOf": "event:부산정치파동", "description": "대통령 직선제를 담은 개헌안 통과" },
    { "@id": "event:국제시장대화재", "@type": "Event", "name": "국제시장 대화재", "date": "1953-01-30", "occurredAt": "place:국제시장", "description": "국제시장 일대를 태운 큰불" },
    { "@id": "event:정전협정체결", "@type": "Event", "name": "정전협정 체결", "date": "1953-07-27", "occurredAt": "place:부산", "description": "한국전쟁 정전협정 체결" },
    { "@id": "event:정부서울환도", "@type": "Event", "name": "정부 서울 환도", "date": "1953-08-15", "occurredAt": "place:부산", "description": "임시수도 기능을 마치고 정부가 서울로 환도" },
    { "@id": "event:부산역전대화재", "@type": "Event", "name": "부산역전 대화재", "date": "1953-11-27", "occurredAt": "place:부산항", "description": "부산역 앞 일대를 태운 대형 화재" },

    { "@id": "work:은지화", "@type": "Work", "name": "은지화", "createdAt": "place:영도", "description": "담뱃갑 은지에 새긴 이중섭의 그림" },
    { "@id": "work:밀다원시대", "@type": "Work", "name": "밀다원시대", "setIn": "place:광복동", "description": "김동리의 소설, 피란기 밀다원다방을 배경으로 함" }
  ]
}
